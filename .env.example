# Déploiement du site vers le serveur (canada) via rsync/SSH.
# Copier ce fichier en .env et remplir. NE JAMAIS commiter le .env réel.
# Le site est servi en statique (contenu de src/) derrière Cloudflare.

# Hôte du serveur (IP Tailscale ou alias SSH)
DEPLOY_HOST=100.65.165.9

# Utilisateur SSH
DEPLOY_USER=akira

# Dossier web servi sur le serveur (racine du vhost)
DEPLOY_PATH=/var/www/stellayr

# Options SSH supplémentaires éventuelles (ex: -i ~/.ssh/ma_cle -p 22)
DEPLOY_SSH_OPTS=
