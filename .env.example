# Deploiement FTP vers l'hebergement OVH (copier ce fichier en .env et remplir).
# NE JAMAIS commiter le fichier .env reel. En CI, ces valeurs vont dans
# GitHub > Settings > Secrets and variables > Actions (memes noms de cles).

# Hote FTP fourni par OVH (ex: ftp.cluster0XX.hosting.ovh.net)
FTP_SERVER=

# Identifiant FTP OVH
FTP_USERNAME=

# Mot de passe FTP OVH
FTP_PASSWORD=

# Protocole : ftps (recommande chez OVH) ou ftp
FTP_PROTOCOL=ftps

# Dossier distant a publier (racine web OVH, ex: ./www/)
FTP_REMOTE_DIR=./www/
