# Déploiement : le serveur (canada) héberge un clone du dépôt et sert src/.
# `npm run deploy` déclenche un `git pull` immédiat sur le serveur via SSH.
# Copier ce fichier en .env et remplir. NE JAMAIS commiter le .env réel.

# Hôte du serveur (IP Tailscale ou alias SSH)
DEPLOY_HOST=100.65.165.9

# Utilisateur SSH
DEPLOY_USER=akira

# Chemin du clone du dépôt sur le serveur (celui dont src/ est servi)
DEPLOY_PATH=/home/akira/sites/stellayr

# Options SSH supplémentaires éventuelles (ex: -i ~/.ssh/ma_cle)
DEPLOY_SSH_OPTS=
