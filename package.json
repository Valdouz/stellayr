{
  "name": "stellayr",
  "version": "1.0.0",
  "private": true,
  "description": "Site officiel du festival S'TELLAYR — Epinay-sous-Senart",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "serve src -l 5173",
    "dev": "serve src -l 5173",
    "assets": "node scripts/build-assets.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:html": "html-validate \"src/**/*.html\"",
    "lint": "npm run format:check && npm run lint:js && npm run lint:css && npm run lint:html",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{js,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.css": [
      "prettier --write",
      "stylelint --fix"
    ],
    "*.html": [
      "prettier --write",
      "html-validate"
    ],
    "*.{json,md,yml,yaml,svg}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "html-validate": "^11.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "serve": "^14.2.6",
    "sharp": "^0.35.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "vitest": "^4.1.9"
  }
}
